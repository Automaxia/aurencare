# ──────────────────────────────────────────────────────────────────────────
# Auren Care · variáveis de ambiente (TEMPLATE)
# Copie para .env.local e preencha os <...>. NUNCA commite valores reais.
# Em produção, os valores reais vivem só no Secret `aurencare-secrets` (k8s).
# ──────────────────────────────────────────────────────────────────────────

# ───────────── NextAuth ─────────────
# Gere com: openssl rand -base64 48
NEXTAUTH_SECRET=<gere-um-segredo-longo>
NEXTAUTH_URL=https://app.audere.ia.br

# ───────────── Banco / Cache ─────────────
DATABASE_URL=postgresql://aurencare:<SENHA>@postgres-service.postgresql.svc.cluster.local:5432/aurencare
REDIS_URL=redis://redis.database.svc.cluster.local:6379

# ───────────── Cripto (dados clínicos em repouso · AES-256) ─────────────
# 32 bytes em hex (64 chars). Gere com: openssl rand -hex 32
# ATENÇÃO: trocar esta chave torna dados já cifrados ilegíveis.
ENCRYPTION_KEY=<64-hex-chars>

# ───────────── Anthropic (IA) ─────────────
ANTHROPIC_API_KEY=sk-ant-...

# ───────────── WhatsApp / Evolution API ─────────────
EVOLUTION_API_URL=http://evolution-api-service.evolution.svc.cluster.local:8080
EVOLUTION_API_KEY=<evolution-api-key>
EVOLUTION_INSTANCE_NAME=AurenCare
# Token compartilhado p/ autenticar o webhook (header x-webhook-token ou ?token=).
# Gere com: openssl rand -hex 24
EVOLUTION_WEBHOOK_TOKEN=<gere-um-token>

# ───────────── Pagar.me ─────────────
PAGARME_API_KEY=sk_live_...
PAGARME_WEBHOOK_SECRET=<webhook-secret-do-painel-pagarme>
# Public key (pk_) p/ tokenizar o cartão da ASSINATURA no browser (API v5).
# ⚠️ NEXT_PUBLIC_* é INLINADO no BUILD — precisa estar no `next build`
# (passe via --build-arg, ver build-push.sh), não só no secret de runtime.
NEXT_PUBLIC_PAGARME_PUBLIC_KEY=pk_live_...

# ───────────── Transcrição (AssemblyAI) ─────────────
ASSEMBLYAI_API_KEY=<assemblyai-key>

# ───────────── Email (Resend) ─────────────
RESEND_API_KEY=re_...
EMAIL_FROM=Auren Care <contato@automaxia.com.br>

# ───────────── Cron (jobs HTTP protegidos) ─────────────
# Bearer exigido por /api/cron/*. Gere com: openssl rand -hex 24
CRON_SECRET=<gere-um-segredo>

# ───────────── Público (browser) · opcional ─────────────
NEXT_PUBLIC_APP_NAME=Auren Care
NEXT_PUBLIC_WS_URL=wss://app.audere.ia.br
