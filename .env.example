# ───────────── NextAuth ─────────────
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=http://localhost:3000

# ───────────── Banco ─────────────
DATABASE_URL=postgresql://aurencare:aurencare@localhost:5432/aurencare
REDIS_URL=redis://localhost:6379

# ───────────── Cripto ─────────────
# 32 bytes em hex (64 chars). Gere com: openssl rand -hex 32
ENCRYPTION_KEY=change-me-32-bytes-hex

# ───────────── Anthropic ─────────────
ANTHROPIC_API_KEY=sk-ant-...

# ───────────── WhatsApp / Evolution API ─────────────
EVOLUTION_API_URL=https://evolution.example.com
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE_NAME=auren-care

# ───────────── Pagar.me ─────────────
PAGARME_API_KEY=sk_test_...
PAGARME_WEBHOOK_SECRET=change-me
PAGARME_ENCRYPTION_KEY=ek_test_...

# ───────────── Transcrição (AssemblyAI) ─────────────
ASSEMBLYAI_API_KEY=change-me

# ───────────── Público (browser) ─────────────
NEXT_PUBLIC_APP_NAME=Auren Care
NEXT_PUBLIC_WS_URL=ws://localhost:3000
