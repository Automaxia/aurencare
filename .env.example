# ──────────────────────────────────────────────────────────────────────────
# Auren Care · variáveis de ambiente
# Valores espelham o ambiente de produção (Secret `aurencare-secrets`).
# Itens ainda como placeholder ainda não têm valor real definido.
# ──────────────────────────────────────────────────────────────────────────

# ───────────── NextAuth ─────────────
# Gere com: openssl rand -base64 48
NEXTAUTH_SECRET=change-me-to-a-long-random-string
NEXTAUTH_URL=https://aurencare.automaxia.com.br

# ───────────── Banco / Cache ─────────────
DATABASE_URL=postgresql://aurencare:b631afe25db6a76960d7c4713cf55c7ed66396aa0e903b2e@postgres-service.postgresql.svc.cluster.local:5432/aurencare
REDIS_URL=redis://redis.database.svc.cluster.local:6379

# ───────────── Cripto (dados clínicos em repouso · AES-256) ─────────────
# 32 bytes em hex (64 chars). Gere com: openssl rand -hex 32
# ATENÇÃO: trocar esta chave torna dados já cifrados ilegíveis.
ENCRYPTION_KEY=7a51134fe641ff48ae2171de9c28c2335681f5c277b0c9cb0c1f25c6f804e244

# ───────────── Anthropic (IA) ─────────────
ANTHROPIC_API_KEY=sk-ant-...

# ───────────── WhatsApp / Evolution API ─────────────
EVOLUTION_API_URL=http://evolution-api-service.evolution.svc.cluster.local:8080
EVOLUTION_API_KEY=7E07750F605B-48FB-98ED-8C5D23701F2E
EVOLUTION_INSTANCE_NAME=AurenCare
# Token compartilhado p/ autenticar o webhook (header x-webhook-token ou ?token=).
# Sem ele, o webhook aceita sem verificar. Gere com: openssl rand -hex 24
EVOLUTION_WEBHOOK_TOKEN=change-me

# ───────────── Pagar.me ─────────────
PAGARME_API_KEY=sk_test_...
PAGARME_WEBHOOK_SECRET=change-me
# Opcional — tokenização de cartão no cliente.
PAGARME_ENCRYPTION_KEY=ek_test_...

# ───────────── Transcrição (AssemblyAI) ─────────────
ASSEMBLYAI_API_KEY=change-me

# ───────────── Email (Resend) ─────────────
RESEND_API_KEY=re_XrKmyH5Q_3J5hEnua1cTtvAZkRtBZEZxU
EMAIL_FROM=Auren Care <contato@automaxia.com.br>

# ───────────── Cron (jobs HTTP protegidos) ─────────────
# Bearer exigido por /api/cron/*. Gere com: openssl rand -hex 24
CRON_SECRET=change-me

# ───────────── Público (browser) · opcional ─────────────
NEXT_PUBLIC_APP_NAME=Auren Care
NEXT_PUBLIC_WS_URL=wss://aurencare.automaxia.com.br
