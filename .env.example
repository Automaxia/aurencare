# ──────────────────────────────────────────────────────────────────────────
# Auren Care · variáveis de ambiente
# Copie para .env.local e preencha. NUNCA commite valores reais.
# Em produção (k8s) estas variáveis vivem no Secret `aurencare-secrets`.
# ──────────────────────────────────────────────────────────────────────────

# ───────────── NextAuth ─────────────
# Segredo de sessão/JWT. Gere com: openssl rand -base64 48
NEXTAUTH_SECRET=change-me-to-a-long-random-string
# URL pública da app (em prod: https://aurencare.automaxia.com.br)
NEXTAUTH_URL=http://localhost:3000

# ───────────── Banco / Cache ─────────────
DATABASE_URL=postgresql://aurencare:aurencare@localhost:5432/aurencare
REDIS_URL=redis://localhost:6379

# ───────────── Cripto (dados clínicos em repouso · AES-256) ─────────────
# 32 bytes em hex (64 chars). Gere com: openssl rand -hex 32
# ATENÇÃO: trocar esta chave torna dados já cifrados ilegíveis. Defina antes
# de qualquer dado clínico real e não rotacione sem plano de migração.
ENCRYPTION_KEY=change-me-32-bytes-hex

# ───────────── Anthropic (IA) ─────────────
ANTHROPIC_API_KEY=sk-ant-...

# ───────────── WhatsApp / Evolution API ─────────────
# Em prod (dentro do cluster): http://evolution-api-service.evolution.svc.cluster.local:8080
EVOLUTION_API_URL=https://evolution.example.com
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE_NAME=AurenCare

# ───────────── Pagar.me ─────────────
PAGARME_API_KEY=sk_test_...
PAGARME_WEBHOOK_SECRET=change-me
# Chave pública de criptografia de cartão no cliente (tokenização). Opcional
# enquanto o checkout transparente de cartão não estiver em uso.
PAGARME_ENCRYPTION_KEY=ek_test_...

# ───────────── Transcrição (AssemblyAI) ─────────────
ASSEMBLYAI_API_KEY=change-me

# ───────────── Email (Resend) ─────────────
# API key (https://resend.com/api-keys). Sem ela, o envio de email vira no-op.
RESEND_API_KEY=re_...
# Remetente — domínio precisa estar verificado no Resend.
EMAIL_FROM=Auren Care <contato@automaxia.com.br>

# ───────────── Cron (jobs HTTP protegidos) ─────────────
# Bearer exigido por /api/cron/* (perguntar-metodo, liberar-confirmacoes).
# Gere com: openssl rand -hex 24
CRON_SECRET=change-me

# ───────────── Público (browser) · opcional ─────────────
# Não referenciadas no código atual; mantidas para uso futuro.
NEXT_PUBLIC_APP_NAME=Auren Care
NEXT_PUBLIC_WS_URL=ws://localhost:3000
