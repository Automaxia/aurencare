#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT_DIR"

info() { printf "\033[36m▸\033[0m %s\n" "$*"; }
warn() { printf "\033[33m!\033[0m %s\n" "$*"; }
err()  { printf "\033[31m✗\033[0m %s\n" "$*" >&2; }

# ────────────────────────────────────────────────────────────────────────────
# Pré-requisitos
# ────────────────────────────────────────────────────────────────────────────
command -v docker >/dev/null 2>&1 || { err "docker não encontrado."; exit 1; }
command -v node   >/dev/null 2>&1 || { err "node não encontrado.";   exit 1; }

# ────────────────────────────────────────────────────────────────────────────
# Postgres + Redis via docker compose
# ────────────────────────────────────────────────────────────────────────────
info "subindo postgres + redis..."
docker compose up -d postgres redis >/dev/null

info "aguardando postgres..."
ready=0
for _ in $(seq 1 30); do
  if docker compose exec -T postgres pg_isready -U aurencare -d aurencare >/dev/null 2>&1; then
    ready=1; break
  fi
  sleep 1
done
[[ "$ready" -eq 1 ]] || { err "postgres não respondeu em 30s."; exit 1; }

# ────────────────────────────────────────────────────────────────────────────
# Secrets idempotentes
# ────────────────────────────────────────────────────────────────────────────
gen_hex() {
  if command -v openssl >/dev/null 2>&1; then openssl rand -hex 32
  else LC_ALL=C tr -dc 'a-f0-9' </dev/urandom | head -c 64; echo
  fi
}

replace_line() {
  local file="$1" key="$2" value="$3"
  sed -i.bak "s|^${key}=.*|${key}=${value}|" "$file"
  rm -f "${file}.bak"
}

if [[ ! -f .env.local ]]; then
  info "criando .env.local com NEXTAUTH_SECRET + ENCRYPTION_KEY gerados..."
  cp .env.example .env.local
  replace_line .env.local NEXTAUTH_SECRET "$(gen_hex)"
  replace_line .env.local ENCRYPTION_KEY  "$(gen_hex)"
  warn "Preencha .env.local com chaves reais: ANTHROPIC, EVOLUTION_*, PAGARME_*, ASSEMBLYAI."
fi

# ────────────────────────────────────────────────────────────────────────────
# Deps + migrate + seed
# ────────────────────────────────────────────────────────────────────────────
if [[ ! -d node_modules ]]; then
  info "instalando dependências..."
  npm install
fi

info "rodando migrations..."
npm run --silent migrate

info "garantindo usuário demo (ana@aurencare.com / auren123)..."
npm run --silent seed

# ────────────────────────────────────────────────────────────────────────────
# Dev server
# ────────────────────────────────────────────────────────────────────────────
info "iniciando Next.js em http://localhost:3000"
info "Login demo: ana@aurencare.com / auren123"
info "Ctrl-C encerra."

exec npm run dev
