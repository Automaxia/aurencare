#!/usr/bin/env bash
# Cria/conecta a instância Evolution e mostra o QR pra escanear no WhatsApp.
# Uso:
#   bin/wa-setup                  # cria/conecta a instância e imprime QR
#   bin/wa-setup --status         # mostra status atual da instância
#   bin/wa-setup --delete         # apaga a instância (pra começar do zero)
#   bin/wa-setup --logout         # desconecta o WhatsApp (mantém a instância)

set -euo pipefail
ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$ROOT"

# carrega .env.local
set -a; source .env.local 2>/dev/null || true; set +a

URL="${EVOLUTION_API_URL:-http://localhost:8080}"
KEY="${EVOLUTION_API_KEY:?EVOLUTION_API_KEY ausente em .env.local}"
INST="${EVOLUTION_INSTANCE_NAME:-auren-care}"
WEBHOOK="http://host.docker.internal:3000/api/webhooks/evolution"

BLUE='\033[36m'; GREEN='\033[32m'; YELLOW='\033[33m'; DIM='\033[90m'; BOLD='\033[1m'; NC='\033[0m'

api() { curl -s -H "apikey: $KEY" "$@"; }

show_qr() {
  local pairing="$1"   # JSON do /instance/connect ou /instance/create
  local code base64
  code=$(echo "$pairing"   | sed -nE 's/.*"code":"([^"]+)".*/\1/p' | head -1)
  base64=$(echo "$pairing" | sed -nE 's/.*"base64":"([^"]+)".*/\1/p' | head -1)

  echo
  echo -e "${BOLD}${GREEN}== QR CODE pronto pra escanear ==${NC}"
  echo

  if command -v qrencode >/dev/null 2>&1 && [ -n "$code" ]; then
    echo -n "$code" | qrencode -t UTF8
    echo -n "$code" | qrencode -o /tmp/auren-wa-qr.png 2>/dev/null || true
  fi

  if [ -n "$base64" ]; then
    echo "${base64#data:image/png;base64,}" | base64 -d > /tmp/auren-wa-qr.png 2>/dev/null || true
    open /tmp/auren-wa-qr.png 2>/dev/null && echo -e "${DIM}QR aberto em /tmp/auren-wa-qr.png${NC}" \
      || echo -e "${YELLOW}não consegui abrir o PNG; veja /tmp/auren-wa-qr.png${NC}"
  fi

  if [ -z "$code" ] && [ -z "$base64" ]; then
    echo -e "${YELLOW}sem QR no response — tenta de novo em alguns segundos${NC}"
    echo "$pairing" | head -c 600
  fi

  echo
  echo -e "${BOLD}Como conectar:${NC}"
  echo "  1) Abra o WhatsApp no celular"
  echo "  2) Vá em ⚙ Configurações → 🖥 Aparelhos conectados → Conectar um aparelho"
  echo "  3) Aponte a câmera pro QR (no PNG aberto)"
  echo "  4) Quando conectar, rode: bin/wa-setup --status"
  echo
}

case "${1:-}" in
  --status)
    echo -e "${BLUE}Status da instância $INST${NC}"
    api "$URL/instance/connectionState/$INST"; echo
    exit 0
    ;;
  --delete)
    echo -e "${YELLOW}Apagando instância $INST...${NC}"
    api -X DELETE "$URL/instance/delete/$INST"; echo
    exit 0
    ;;
  --logout)
    echo -e "${YELLOW}Desconectando WhatsApp de $INST...${NC}"
    api -X DELETE "$URL/instance/logout/$INST"; echo
    exit 0
    ;;
esac

echo -e "${BOLD}Setup WhatsApp · Evolution API${NC}"
echo -e "${DIM}URL=$URL · Instância=$INST · Webhook=$WEBHOOK${NC}"
echo

# 1) instância existe?
existe=$(api "$URL/instance/fetchInstances" | grep -c "\"name\":\"$INST\"" || true)
if [ "$existe" -eq 0 ]; then
  echo -e "${BLUE}1/3${NC} criando instância $INST..."
  resp=$(api -X POST "$URL/instance/create" \
    -H "Content-Type: application/json" \
    -d "{
      \"instanceName\": \"$INST\",
      \"integration\": \"WHATSAPP-BAILEYS\",
      \"qrcode\": true,
      \"webhook\": {
        \"url\": \"$WEBHOOK\",
        \"byEvents\": false,
        \"base64\": false,
        \"events\": [\"MESSAGES_UPSERT\", \"CONNECTION_UPDATE\", \"QRCODE_UPDATED\"]
      }
    }")
  if echo "$resp" | grep -q '"error"'; then
    echo -e "\033[31m✗ falha ao criar:\033[0m $resp"
    exit 1
  fi
  echo -e "${GREEN}✓ instância criada${NC}"
  if echo "$resp" | grep -q '"base64"'; then
    show_qr "$resp"
    exit 0
  fi
else
  echo -e "${DIM}1/3 instância $INST já existe${NC}"
fi

# 2) já está conectada?
st=$(api "$URL/instance/connectionState/$INST" | sed -nE 's/.*"state":"([^"]+)".*/\1/p' | head -1)
echo -e "${BLUE}2/3${NC} estado atual: ${BOLD}$st${NC}"
if [ "$st" = "open" ]; then
  echo -e "${GREEN}✓ já conectado!${NC} Teste com: bin/wa-sim 5561982494953 'oi'"
  exit 0
fi

# 3) requisita pareamento → QR (vem via webhook qrcode.updated → Redis)
echo -e "${BLUE}3/3${NC} aguardando QR aparecer (via webhook)..."
api "$URL/instance/connect/$INST" > /dev/null

for i in $(seq 1 30); do
  resp=$(curl -s "http://localhost:3000/api/wa/qr?inst=$INST")
  if echo "$resp" | grep -q '"base64"'; then
    show_qr "$resp"
    exit 0
  fi
  sleep 1
done
echo -e "${YELLOW}não recebi QR em 30s. Possíveis causas:${NC}"
echo "  · Auren dev server não está rodando (npm run dev)"
echo "  · Redis não está conectado"
echo "  · Rode 'docker logs aurencare-evolution --tail 20' pra ver erros"
